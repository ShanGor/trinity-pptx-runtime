#!/bin/bash
#
# Trinity Office Runtime - Main Entry Point
# Wraps LibreOffice, Python tools, and Node.js in a sandboxed environment
#

set -euo pipefail

# Configuration
SCRIPT_DIR="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")" && pwd)"
RUNTIME_DIR="${SCRIPT_DIR}"
VERSION_FILE="${RUNTIME_DIR}/VERSION"

# Default settings
USE_BWRAP=true
BWRAP_OPTS=""
CLI_BASE_DIR="$PWD"
INPUT_DIR=""
WORK_DIR=""
VERBOSE=false

# Show version
show_version() {
    if [ -f "$VERSION_FILE" ]; then
        head -n1 "$VERSION_FILE"
    else
        echo "unknown"
    fi
}

# Show help
show_help() {
    cat << 'EOF'
Trinity Office Runtime - Sandboxed office document tooling

The convenience commands below are PPTX-focused; use `exec` for broader
office formats through bundled LibreOffice and other runtime tools.

Usage: trinity-office [OPTIONS] COMMAND [ARGS...]

Commands:
  convert <input.pptx> [output.pdf]    Convert PPTX to PDF
  extract <input.pptx>                 Extract text content from PPTX
  thumbnail <input.pptx> [output.jpg]  Generate thumbnail preview
  create <script.js> [output.pptx]     Create PPTX from JavaScript (pptxgenjs)
  exec <command> [args...]             Execute arbitrary command in sandbox

Options:
  -h, --help           Show this help message
  -v, --version        Show version information
  --no-sandbox         Disable bubblewrap sandbox (not recommended)
  --work-dir <dir>     Set working directory for input/output files
  --verbose            Enable verbose output

Examples:
  trinity-office convert presentation.pptx output.pdf
  trinity-office extract slides.pptx
  trinity-office create my-presentation.js deck.pptx
  trinity-office exec soffice --headless --convert-to pdf report.docx

Environment Variables:
  TRINITY_OFFICE_RUNTIME    Path to runtime directory (overrides auto-detect)
  TRINITY_NO_SANDBOX      Set to "1" to disable sandbox
  TRINITY_BWRAP_OPTS      Additional bubblewrap options

EOF
}

# Log verbose messages
log() {
    if [ "$VERBOSE" = true ]; then
        echo "[trinity-office] $*" >&2
    fi
}

run_host_find() {
    env -u LD_LIBRARY_PATH -u LD_PRELOAD -u LD_AUDIT PATH="/usr/bin:/bin" find "$@"
}

run_markitdown() {
    local input_path="$1"
    local script='
import sys

last_error = None
MarkItDown = None
for module_name in ("markitdown", "markitdown_no_magika"):
    try:
        module = __import__(module_name, fromlist=["MarkItDown"])
        MarkItDown = getattr(module, "MarkItDown")
        break
    except Exception as exc:
        last_error = exc

if MarkItDown is None:
    raise last_error or ModuleNotFoundError("No MarkItDown module is available")

result = MarkItDown().convert(sys.argv[1])
output = getattr(result, "markdown", None)
if output is None:
    output = getattr(result, "text_content", "")
sys.stdout.write(output)
'

    run_sandboxed python3 -c "$script" "$input_path"
}

# Detect if running in sandboxed environment
needs_shim() {
    # Check if AF_UNIX sockets are blocked
    python3 -c "import socket; s = socket.socket(socket.AF_UNIX, socket.SOCK_STREAM); s.close()" 2>/dev/null || return 0
    return 1
}

discover_pythonpath() {
    local prefix="${1:-/runtime}"
    local path
    local python_path=""
    local paths=""

    paths="$(run_host_find -L "$RUNTIME_DIR/lib" -mindepth 2 -maxdepth 2 -type d \( -name dist-packages -o -name site-packages \) 2>/dev/null || true)"
    while IFS= read -r path; do
        [ -n "$path" ] || continue
        if [ -n "$python_path" ]; then
            python_path="${python_path}:"
        fi
        python_path="${python_path}${prefix}${path#$RUNTIME_DIR}"
    done <<< "$paths"

    echo "$python_path"
}

discover_node_path() {
    local prefix="${1:-/runtime}"
    local path
    local node_path=""
    local root
    local paths=""
    local -a node_roots=(
        "$RUNTIME_DIR/lib"
        "$RUNTIME_DIR/usr/lib"
        "$RUNTIME_DIR/rootfs/usr/local/lib"
    )
    local -a nodejs_dirs=(
        "$RUNTIME_DIR/share/nodejs"
        "$RUNTIME_DIR/usr/share/nodejs"
        "$RUNTIME_DIR/rootfs/usr/share/nodejs"
    )

    for root in "${node_roots[@]}"; do
        if [ ! -d "$root" ]; then
            continue
        fi

        paths="$(run_host_find -L "$root" -mindepth 1 -maxdepth 2 -type d -name node_modules 2>/dev/null || true)"
        while IFS= read -r path; do
            [ -n "$path" ] || continue
            if [ -n "$node_path" ]; then
                node_path="${node_path}:"
            fi
            node_path="${node_path}${prefix}${path#$RUNTIME_DIR}"
        done <<< "$paths"
    done

    for path in "${nodejs_dirs[@]}"; do
        node_path="$(append_path_entry "$node_path" "${prefix}${path#$RUNTIME_DIR}")"
    done

    echo "$node_path"
}

append_path_entry() {
    local current="$1"
    local entry="$2"
    local require_dir_check="${3:-1}"

    if [ -z "$entry" ]; then
        echo "$current"
        return
    fi

    if [ "$require_dir_check" = "1" ] && [ ! -d "$entry" ]; then
        echo "$current"
        return
    fi

    if [ -z "$current" ]; then
        echo "$entry"
        return
    fi

    case ":$current:" in
        *":$entry:"*)
            echo "$current"
            ;;
        *)
            echo "${current}:$entry"
            ;;
    esac
}

discover_library_path() {
    local prefix="${1:-/runtime}"
    local library_path=""
    local dir
    local root
    local paths=""
    local -a library_roots=("$RUNTIME_DIR/lib" "$RUNTIME_DIR/usr/lib")

    # Keep the loader path constrained to runtime system-library roots.
    # Scanning every .so-containing directory (for example Python package
    # trees) is too broad and can destabilize non-sandboxed Python startup.
    for root in "${library_roots[@]}"; do
        if [ ! -d "$root" ]; then
            continue
        fi

        library_path="$(append_path_entry "$library_path" "${prefix}${root#$RUNTIME_DIR}" 0)"

        paths="$(run_host_find -L "$root" -mindepth 1 -maxdepth 1 -type d -name '*-linux-gnu' 2>/dev/null || true)"
        while IFS= read -r dir; do
            [ -n "$dir" ] || continue
            library_path="$(append_path_entry "$library_path" "${prefix}${dir#$RUNTIME_DIR}" 0)"
        done <<< "$paths"
    done

    echo "$library_path"
}

discover_libreoffice_program_path() {
    local prefix="${1:-/runtime}"
    local program_path="${prefix}/lib/libreoffice/program"

    if [ -d "$RUNTIME_DIR/lib/libreoffice/program" ]; then
        echo "$program_path"
    else
        echo ""
    fi
}

discover_dri_driver_path() {
    local prefix="${1:-/runtime}"
    local path
    local dri_path=""
    local root
    local paths=""
    local -a library_roots=("$RUNTIME_DIR/lib" "$RUNTIME_DIR/usr/lib")

    for root in "${library_roots[@]}"; do
        if [ ! -d "$root" ]; then
            continue
        fi

        paths="$(run_host_find -L "$root" -mindepth 2 -maxdepth 4 -type d -name dri 2>/dev/null || true)"
        while IFS= read -r path; do
            [ -n "$path" ] || continue
            if [ -n "$dri_path" ]; then
                dri_path="${dri_path}:"
            fi
            dri_path="${dri_path}${prefix}${path#$RUNTIME_DIR}"
        done <<< "$paths"
    done

    echo "$dri_path"
}

discover_rootfs_command_guest_path() {
    local cmd="$1"
    local rootfs="${RUNTIME_DIR}/rootfs"
    local candidate=""

    for candidate in \
        "/usr/local/bin/${cmd}" \
        "/usr/bin/${cmd}" \
        "/bin/${cmd}"
    do
        if [ -x "${rootfs}${candidate}" ]; then
            echo "$candidate"
            return 0
        fi
    done

    return 1
}

discover_rootfs_command_host_path() {
    local cmd="$1"
    local rootfs="${RUNTIME_DIR}/rootfs"
    local candidate=""

    for candidate in \
        "${rootfs}/usr/local/bin/${cmd}" \
        "${rootfs}/usr/bin/${cmd}" \
        "${rootfs}/bin/${cmd}"
    do
        if [ -x "$candidate" ]; then
            echo "$candidate"
            return 0
        fi
    done

    return 1
}

discover_rootfs_node_path() {
    local rootfs="${RUNTIME_DIR}/rootfs"
    local node_path=""
    local path=""

    for path in \
        /usr/local/lib/node_modules \
        /usr/lib/node_modules \
        /usr/share/nodejs
    do
        node_path="$(append_path_entry "$node_path" "$path" "$( [ -d "${rootfs}${path}" ] && echo 0 || echo 1 )")"
    done

    echo "$node_path"
}

discover_rootfs_library_path() {
    local prefix="${1:-$RUNTIME_DIR/rootfs}"
    local rootfs="${RUNTIME_DIR}/rootfs"
    local library_path=""
    local dir=""
    local root=""
    local paths=""
    local -a library_roots=(
        "$rootfs/lib"
        "$rootfs/lib64"
        "$rootfs/usr/lib"
        "$rootfs/usr/lib64"
    )

    for root in "${library_roots[@]}"; do
        if [ ! -e "$root" ] && [ ! -L "$root" ]; then
            continue
        fi

        library_path="$(append_path_entry "$library_path" "${prefix}${root#$rootfs}" 0)"

        if [ ! -d "$root" ]; then
            continue
        fi

        paths="$(run_host_find -L "$root" -mindepth 1 -maxdepth 1 -type d -name '*-linux-gnu' 2>/dev/null || true)"
        while IFS= read -r dir; do
            [ -n "$dir" ] || continue
            library_path="$(append_path_entry "$library_path" "${prefix}${dir#$rootfs}" 0)"
        done <<< "$paths"
    done

    echo "$library_path"
}

discover_rootfs_loader_path() {
    local rootfs="${RUNTIME_DIR}/rootfs"
    local candidate=""

    for candidate in \
        "${rootfs}/lib64/ld-linux-x86-64.so.2" \
        "${rootfs}/lib/x86_64-linux-gnu/ld-linux-x86-64.so.2" \
        "${rootfs}/lib/ld-linux-aarch64.so.1" \
        "${rootfs}/lib/aarch64-linux-gnu/ld-linux-aarch64.so.1"
    do
        if [ -x "$candidate" ]; then
            echo "$candidate"
            return 0
        fi
    done

    return 1
}

command_is_elf_binary() {
    local path="$1"
    local magic=""

    [ -f "$path" ] || return 1

    exec 3<"$path" || return 1
    IFS= read -r -n 4 magic <&3 || true
    exec 3<&-

    [ "$magic" = $'\177ELF' ]
}

command_needs_libreoffice_env() {
    case "${1:-}" in
        soffice)
            return 0
            ;;
        *)
            return 1
            ;;
    esac
}

command_requires_rootfs_bwrap() {
    case "${1:-}" in
        soffice|node|npm|npx)
            return 0
            ;;
        *)
            return 1
            ;;
    esac
}

runtime_has_libreoffice_rootfs() {
    [ -x "$RUNTIME_DIR/rootfs/usr/bin/soffice" ] || return 1

    if [ ! -d "$RUNTIME_DIR/rootfs/usr/lib/libreoffice" ] && \
        ! compgen -G "$RUNTIME_DIR/rootfs/opt/libreoffice*/program" >/dev/null; then
        return 1
    fi

    if [ ! -d "$RUNTIME_DIR/rootfs/etc/libreoffice" ] && \
        ! compgen -G "$RUNTIME_DIR/rootfs/opt/libreoffice*/share/registry" >/dev/null; then
        return 1
    fi

    return 0
}

command_uses_libreoffice_rootfs() {
    command_needs_libreoffice_env "${1:-}" || return 1
    runtime_has_libreoffice_rootfs
}

command_uses_runtime_rootfs() {
    discover_rootfs_command_guest_path "${1:-}" >/dev/null 2>&1
}

rewrite_workdir_args() {
    local arg

    rewritten_args=()

    if [ -z "$WORK_DIR" ] && [ -z "$INPUT_DIR" ]; then
        rewritten_args=("$@")
        return
    fi

    for arg in "$@"; do
        case "$arg" in
            /input)
                if [ -n "$INPUT_DIR" ]; then
                    rewritten_args+=("$INPUT_DIR")
                else
                    rewritten_args+=("$arg")
                fi
                ;;
            /input/*)
                if [ -n "$INPUT_DIR" ]; then
                    rewritten_args+=("${INPUT_DIR}/${arg#/input/}")
                else
                    rewritten_args+=("$arg")
                fi
                ;;
            /work)
                rewritten_args+=("$WORK_DIR")
                ;;
            /work/*)
                rewritten_args+=("${WORK_DIR}/${arg#/work/}")
                ;;
            *)
                rewritten_args+=("$arg")
                ;;
        esac
    done
}

resolve_cli_path() {
    local path="$1"

    case "$path" in
        /*)
            printf '%s\n' "$path"
            ;;
        *)
            printf '%s/%s\n' "$CLI_BASE_DIR" "$path"
            ;;
    esac
}

normalize_existing_file_path() {
    local path="$1"
    local resolved_path
    local resolved_dir

    resolved_path="$(resolve_cli_path "$path")"
    if [ ! -f "$resolved_path" ]; then
        echo "Error: Input file not found: $path" >&2
        exit 1
    fi

    resolved_dir="$(cd "$(dirname "$resolved_path")" && pwd)"
    printf '%s/%s\n' "$resolved_dir" "$(basename "$resolved_path")"
}

normalize_output_path() {
    local path="$1"
    local resolved_path
    local resolved_dir

    resolved_path="$(resolve_cli_path "$path")"
    resolved_dir="$(dirname "$resolved_path")"
    if [ ! -d "$resolved_dir" ]; then
        echo "Error: Output directory not found: $resolved_dir" >&2
        exit 1
    fi

    resolved_dir="$(cd "$resolved_dir" && pwd)"
    printf '%s/%s\n' "$resolved_dir" "$(basename "$resolved_path")"
}

render_text_pdf() {
    local output_path="$1"
    local source_name="$2"
    local markdown_content="${3:-}"
    local markdown_file
    local render_status=0

    markdown_file="$(mktemp "${TMPDIR:-/tmp}/trinity-office-markdown.XXXXXX")"
    printf '%s' "$markdown_content" > "$markdown_file"

    TEXT_PDF_OUTPUT="$output_path" \
    TEXT_PDF_SOURCE="$source_name" \
    TEXT_PDF_MARKDOWN_FILE="$markdown_file" \
    python3 - <<'PY'
import os
import re
import textwrap

output_path = os.environ["TEXT_PDF_OUTPUT"]
source_name = os.environ.get("TEXT_PDF_SOURCE", "presentation.pptx")
markdown_file = os.environ["TEXT_PDF_MARKDOWN_FILE"]
with open(markdown_file, "r", encoding="utf-8", errors="replace") as handle:
    markdown = handle.read()

def escape_pdf_text(text: str) -> str:
    return text.replace("\\", "\\\\").replace("(", "\\(").replace(")", "\\)")

def normalize_markdown(content: str) -> list[str]:
    content = content.replace("\r\n", "\n").replace("\r", "\n")
    content = re.sub(r"<!--\s*Slide number:\s*(\d+)\s*-->", r"\n\nSlide \1\n", content)
    content = re.sub(r"!\[[^\]]*\]\([^)]+\)", "", content)

    lines: list[str] = []
    for raw_line in content.splitlines():
        line = raw_line.strip()
        line = re.sub(r"^#{1,6}\s*", "", line)
        line = re.sub(r"^\s*[-*]\s+", "- ", line)
        if not line:
            if lines and lines[-1] != "":
                lines.append("")
            continue
        lines.append(line)

    while lines and lines[-1] == "":
        lines.pop()
    return lines

header_lines = [
    "Trinity Office fallback preview",
    f"Source: {source_name}",
    "Visual presentation-to-PDF conversion failed; this PDF contains extracted slide text.",
    "",
]

body_lines = normalize_markdown(markdown)
if body_lines:
    logical_lines = header_lines + body_lines
else:
    logical_lines = header_lines + ["No extractable slide text was available."]

wrapped_lines: list[str] = []
for line in logical_lines:
    if line == "":
        wrapped_lines.append("")
        continue
    segments = textwrap.wrap(
        line,
        width=92,
        replace_whitespace=False,
        drop_whitespace=False,
    )
    wrapped_lines.extend(segments or [""])

page_width = 612
page_height = 792
margin_x = 54
top_y = 750
bottom_margin = 54
line_height = 14
lines_per_page = max(1, int((top_y - bottom_margin) / line_height))
pages = [
    wrapped_lines[i : i + lines_per_page]
    for i in range(0, len(wrapped_lines), lines_per_page)
] or [["No extractable slide text was available."]]

objects: list[bytes] = []

def add_object(data: bytes | str) -> int:
    if isinstance(data, str):
        data = data.encode("latin-1", "replace")
    objects.append(data)
    return len(objects)

font_obj = add_object("<< /Type /Font /Subtype /Type1 /BaseFont /Helvetica >>")
page_obj_indexes: list[int] = []

for page_lines in pages:
    stream_lines = ["BT", "/F1 11 Tf", "14 TL", f"{margin_x} {top_y} Td"]
    for line in page_lines:
        stream_lines.append(f"({escape_pdf_text(line)}) Tj")
        stream_lines.append("T*")
    stream_lines.append("ET")
    stream = "\n".join(stream_lines).encode("latin-1", "replace")
    content_obj = add_object(
        b"<< /Length %d >>\nstream\n" % len(stream) + stream + b"\nendstream"
    )
    page_obj = add_object(
        (
            "<< /Type /Page /Parent PAGES_OBJ /MediaBox [0 0 "
            f"{page_width} {page_height}] /Resources << /Font << /F1 "
            f"{font_obj} 0 R >> >> /Contents {content_obj} 0 R >>"
        )
    )
    page_obj_indexes.append(page_obj)

pages_obj = add_object(
    "<< /Type /Pages /Count "
    f"{len(page_obj_indexes)} /Kids [{' '.join(f'{idx} 0 R' for idx in page_obj_indexes)}] >>"
)
catalog_obj = add_object(f"<< /Type /Catalog /Pages {pages_obj} 0 R >>")

for index, data in enumerate(objects):
    if b"PAGES_OBJ" in data:
        objects[index] = data.replace(b"PAGES_OBJ", str(pages_obj).encode("ascii"))

with open(output_path, "wb") as pdf:
    pdf.write(b"%PDF-1.4\n%\xe2\xe3\xcf\xd3\n")
    offsets = [0]
    for number, data in enumerate(objects, start=1):
        offsets.append(pdf.tell())
        pdf.write(f"{number} 0 obj\n".encode("ascii"))
        pdf.write(data)
        if not data.endswith(b"\n"):
            pdf.write(b"\n")
        pdf.write(b"endobj\n")
    xref_offset = pdf.tell()
    pdf.write(f"xref\n0 {len(objects) + 1}\n".encode("ascii"))
    pdf.write(b"0000000000 65535 f \n")
    for offset in offsets[1:]:
        pdf.write(f"{offset:010d} 00000 n \n".encode("ascii"))
    pdf.write(
        (
            f"trailer\n<< /Size {len(objects) + 1} /Root {catalog_obj} 0 R >>\n"
            f"startxref\n{xref_offset}\n%%EOF\n"
        ).encode("ascii")
    )
PY
    render_status=$?
    rm -f "$markdown_file"
    return "$render_status"
}

generate_fallback_pdf() {
    local input_name="$1"
    local output_path="$2"
    local markdown_content=""

    if markdown_content="$(run_markitdown "/input/$input_name" 2>/dev/null)"; then
        :
    else
        markdown_content=""
    fi

    render_text_pdf "$output_path" "$input_name" "$markdown_content"
}

generate_pdf_preview() {
    local input_name="$1"
    local output_path="$2"
    local visual_output="${WORK_DIR}/${input_name%.pptx}.pdf"
    local visual_status=0

    rm -f "$visual_output"
    if run_sandboxed soffice --headless --convert-to pdf --outdir /work "/input/$input_name"; then
        visual_status=0
    else
        visual_status=$?
    fi

    if [ -f "$visual_output" ]; then
        if [ "$visual_output" != "$output_path" ]; then
            mv "$visual_output" "$output_path"
        fi
        return 0
    fi

    log "LibreOffice conversion failed with status ${visual_status}; generating extracted-text PDF fallback"
    generate_fallback_pdf "$input_name" "$output_path"
}

# Setup environment variables for LibreOffice
setup_env() {
    local tool_cmd="${1:-}"
    local env_vars=""
    local python_path=""
    local node_path=""
    local library_path=""
    local libreoffice_program_path=""
    local dri_driver_path=""
    
    # Set HOME to a writable tmpfs location
    env_vars="${env_vars} --setenv HOME /tmp/home"

    # Add runtime bin to PATH for node, python, etc.
    env_vars="${env_vars} --setenv PATH /runtime/bin:/usr/bin:/bin"
    env_vars="${env_vars} --setenv LANG C.UTF-8"
    env_vars="${env_vars} --setenv LC_ALL C.UTF-8"

    # Ensure bundled Python packages are importable across both /usr and
    # /usr/local-derived layouts.
    python_path="$(discover_pythonpath /runtime)"
    if [ -n "$python_path" ]; then
        env_vars="${env_vars} --setenv PYTHONPATH ${python_path}"
    fi
    
    if command_needs_libreoffice_env "$tool_cmd"; then
        # Generic runtime commands do not need an overridden loader path and are
        # more stable without one. Keep the loader override only for LibreOffice.
        library_path="$(discover_library_path /runtime)"
        libreoffice_program_path="$(discover_libreoffice_program_path /runtime)"
        library_path="$(append_path_entry "$library_path" "$libreoffice_program_path" 0)"
        if [ -n "$library_path" ]; then
            env_vars="${env_vars} --setenv LD_LIBRARY_PATH ${library_path}:/lib:/lib64"
        else
            env_vars="${env_vars} --setenv LD_LIBRARY_PATH /runtime/lib:/lib:/lib64"
        fi
    fi
    
    # Node.js modules path
    node_path="$(discover_node_path /runtime)"
    if [ -n "$node_path" ]; then
        env_vars="${env_vars} --setenv NODE_PATH ${node_path}"
    fi

    if command_needs_libreoffice_env "$tool_cmd"; then
        # Prefer deterministic software rendering for headless LibreOffice use.
        env_vars="${env_vars} --setenv SAL_DISABLESKIA 1"
        env_vars="${env_vars} --setenv LIBGL_ALWAYS_SOFTWARE 1"

        dri_driver_path="$(discover_dri_driver_path /runtime)"
        if [ -n "$dri_driver_path" ]; then
            env_vars="${env_vars} --setenv LIBGL_DRIVERS_PATH ${dri_driver_path}"
        fi

        # LibreOffice specific paths
        env_vars="${env_vars} --setenv URE_BOOTSTRAP vnd.sun.star.pathname:/runtime/lib/libreoffice/program/fundamentalrc"
    fi
    
    echo "$env_vars"
}

setup_rootfs_env() {
    local tool_cmd="${1:-}"
    local env_vars=""
    local node_path=""

    env_vars="${env_vars} --setenv HOME /tmp/home"
    env_vars="${env_vars} --setenv PATH /usr/local/bin:/usr/bin:/bin"
    env_vars="${env_vars} --setenv LANG C.UTF-8"
    env_vars="${env_vars} --setenv LC_ALL C.UTF-8"

    node_path="$(discover_rootfs_node_path)"
    if [ -n "$node_path" ]; then
        env_vars="${env_vars} --setenv NODE_PATH ${node_path}"
    fi

    if command_needs_libreoffice_env "$tool_cmd"; then
        env_vars="${env_vars} --setenv SAL_DISABLESKIA 1"
        env_vars="${env_vars} --setenv LIBGL_ALWAYS_SOFTWARE 1"
    fi

    echo "$env_vars"
}

# Build bubblewrap command
append_ro_bind_if_exists() {
    local cmd="$1"
    local source="$2"
    local target="$3"

    if [ -e "$source" ] || [ -L "$source" ]; then
        echo "${cmd} --ro-bind ${source} ${target}"
    else
        echo "$cmd"
    fi
}

build_rootfs_bwrap_cmd() {
    local tool_cmd="${1:-}"
    local rootfs="${RUNTIME_DIR}/rootfs"
    local cmd=""

    cmd="${cmd} --unshare-all"
    cmd="${cmd} --share-net"
    cmd="${cmd} --die-with-parent"

    cmd="$(append_ro_bind_if_exists "$cmd" "${rootfs}/bin" /bin)"
    cmd="$(append_ro_bind_if_exists "$cmd" "${rootfs}/lib" /lib)"
    cmd="$(append_ro_bind_if_exists "$cmd" "${rootfs}/lib64" /lib64)"
    cmd="$(append_ro_bind_if_exists "$cmd" "${rootfs}/opt" /opt)"
    cmd="$(append_ro_bind_if_exists "$cmd" "${rootfs}/usr/bin" /usr/bin)"
    cmd="$(append_ro_bind_if_exists "$cmd" "${rootfs}/usr/lib" /usr/lib)"
    cmd="$(append_ro_bind_if_exists "$cmd" "${rootfs}/usr/lib64" /usr/lib64)"
    cmd="$(append_ro_bind_if_exists "$cmd" "${rootfs}/usr/local" /usr/local)"
    cmd="$(append_ro_bind_if_exists "$cmd" "${rootfs}/usr/share" /usr/share)"
    cmd="$(append_ro_bind_if_exists "$cmd" "${rootfs}/etc" /etc)"
    cmd="$(append_ro_bind_if_exists "$cmd" "${rootfs}/var/lib/libreoffice" /var/lib/libreoffice)"
    cmd="$(append_ro_bind_if_exists "$cmd" "${rootfs}/var/spool/libreoffice" /var/spool/libreoffice)"

    cmd="${cmd} --proc /proc"
    cmd="${cmd} --dev /dev"
    cmd="${cmd} --tmpfs /tmp"
    cmd="${cmd} --tmpfs /tmp/home"

    if [ -n "$WORK_DIR" ] && [ -d "$WORK_DIR" ]; then
        cmd="${cmd} --bind ${WORK_DIR} /work"
        cmd="${cmd} --setenv WORKDIR /work"
    fi

    if [ -n "$INPUT_DIR" ] && [ -d "$INPUT_DIR" ]; then
        cmd="${cmd} --ro-bind ${INPUT_DIR} /input"
        cmd="${cmd} --setenv INPUTDIR /input"
    fi

    cmd="${cmd} $(setup_rootfs_env "$tool_cmd")"

    if [ -n "${TRINITY_BWRAP_OPTS:-}" ]; then
        cmd="${cmd} ${TRINITY_BWRAP_OPTS}"
    fi

    echo "$cmd"
}

build_bwrap_cmd() {
    local tool_cmd="${1:-}"
    local cmd=""

    if command_uses_runtime_rootfs "$tool_cmd"; then
        build_rootfs_bwrap_cmd "$tool_cmd"
        return
    fi
    
    # Basic sandbox setup
    cmd="${cmd} --unshare-all"
    cmd="${cmd} --share-net"
    cmd="${cmd} --die-with-parent"
    
    # Mount runtime as read-only
    cmd="${cmd} --ro-bind ${RUNTIME_DIR} /runtime"
    
    # Mount system directories for dependencies
    cmd="${cmd} --ro-bind /bin /bin"
    cmd="${cmd} --ro-bind /lib /lib"
    cmd="${cmd} --ro-bind /lib64 /lib64"
    cmd="${cmd} --ro-bind /usr/bin /usr/bin"
    cmd="${cmd} --ro-bind /usr/lib /usr/lib"
    cmd="${cmd} --ro-bind /usr/lib64 /usr/lib64"
    cmd="${cmd} --ro-bind /usr/share /usr/share"
    cmd="${cmd} --ro-bind /etc /etc"
    
    # Proc and dev filesystems
    cmd="${cmd} --proc /proc"
    cmd="${cmd} --dev /dev"
    
    # Temporary directories
    cmd="${cmd} --tmpfs /tmp"
    cmd="${cmd} --tmpfs /tmp/home"
    
    # Working directory (if specified)
    if [ -n "$WORK_DIR" ] && [ -d "$WORK_DIR" ]; then
        cmd="${cmd} --bind ${WORK_DIR} /work"
        cmd="${cmd} --setenv WORKDIR /work"
    fi

    if [ -n "$INPUT_DIR" ] && [ -d "$INPUT_DIR" ]; then
        cmd="${cmd} --ro-bind ${INPUT_DIR} /input"
        cmd="${cmd} --setenv INPUTDIR /input"
    fi
    
    # Environment variables
    cmd="${cmd} $(setup_env "$tool_cmd")"
    
    # Additional user-specified options
    if [ -n "${TRINITY_BWRAP_OPTS:-}" ]; then
        cmd="${cmd} ${TRINITY_BWRAP_OPTS}"
    fi
    
    echo "$cmd"
}

run_rootfs_command_without_sandbox() {
    local cmd="$1"
    shift
    local runtime_home="${TMPDIR:-/tmp}/trinity-office-home"
    local rootfs="${RUNTIME_DIR}/rootfs"
    local rootfs_command=""
    local rootfs_loader=""
    local rootfs_library_path=""
    local runtime_nodepath=""
    local -a exec_cmd=()

    rootfs_command="$(discover_rootfs_command_host_path "$cmd")"
    if [ -z "$rootfs_command" ]; then
        echo "Error: Runtime command not found in bundled rootfs: $cmd" >&2
        exit 1
    fi

    mkdir -p "$runtime_home"
    runtime_nodepath="$(discover_rootfs_node_path)"

    local chroot_bin=""
    for chroot_bin in /usr/sbin/chroot /sbin/chroot; do
        if [ -x "$chroot_bin" ]; then
            break
        fi
        chroot_bin=""
    done

    if command -v unshare &> /dev/null && [ -n "$chroot_bin" ]; then
        mkdir -p "$rootfs/tmp/home"

        if [ -n "$WORK_DIR" ] && [ -d "$WORK_DIR" ]; then
            mkdir -p "$rootfs/work"
            mount --bind "$WORK_DIR" "$rootfs/work" 2>/dev/null || true
        fi

        if [ -n "$INPUT_DIR" ] && [ -d "$INPUT_DIR" ]; then
            mkdir -p "$rootfs/input"
            mount --bind -o ro "$INPUT_DIR" "$rootfs/input" 2>/dev/null || true
        fi

        local -a rewritten_args=()
        local arg
        for arg in "$@"; do
            if [ -n "$INPUT_DIR" ] && [ "$arg" = "$INPUT_DIR" ]; then
                rewritten_args+=("/input")
            elif [ -n "$INPUT_DIR" ] && [[ "$arg" == "$INPUT_DIR"/* ]]; then
                rewritten_args+=("/input/${arg#$INPUT_DIR/}")
            elif [ -n "$WORK_DIR" ] && [ "$arg" = "$WORK_DIR" ]; then
                rewritten_args+=("/work")
            elif [ -n "$WORK_DIR" ] && [[ "$arg" == "$WORK_DIR"/* ]]; then
                rewritten_args+=("/work/${arg#$WORK_DIR/}")
            else
                rewritten_args+=("$arg")
            fi
        done

        local guest_cmd
        guest_cmd="$(discover_rootfs_command_guest_path "$cmd")"

        HOME="/tmp/home" \
        LANG="C.UTF-8" \
        LC_ALL="C.UTF-8" \
        PATH="/usr/local/bin:/usr/bin:/bin" \
        NODE_PATH="$runtime_nodepath" \
        unshare -mr "$chroot_bin" "$rootfs" "$guest_cmd" "${rewritten_args[@]}"
        local rc=$?

        if [ -n "$WORK_DIR" ] && [ -d "$rootfs/work" ]; then
            umount -l "$rootfs/work" 2>/dev/null || true
        fi
        if [ -n "$INPUT_DIR" ] && [ -d "$rootfs/input" ]; then
            umount -l "$rootfs/input" 2>/dev/null || true
        fi

        return $rc
    fi

    if command_is_elf_binary "$rootfs_command"; then
        rootfs_loader="$(discover_rootfs_loader_path)"
        rootfs_library_path="$(discover_rootfs_library_path)"
        if [ -z "$rootfs_loader" ] || [ -z "$rootfs_library_path" ]; then
            echo "Error: Bundled runtime loader paths are incomplete for command: $cmd" >&2
            exit 1
        fi
        exec_cmd=("$rootfs_loader" "--library-path" "$rootfs_library_path" "$rootfs_command")
    else
        exec_cmd=("$rootfs_command")
    fi

    HOME="$runtime_home" \
    LANG="C.UTF-8" \
    LC_ALL="C.UTF-8" \
    PATH="${RUNTIME_DIR}/rootfs/usr/local/bin:${RUNTIME_DIR}/rootfs/usr/bin:${RUNTIME_DIR}/rootfs/bin:/usr/bin:/bin" \
    NODE_PATH="$runtime_nodepath" \
    "${exec_cmd[@]}" "$@"
}

# Run a command in the sandbox and return its status to the caller.
run_sandboxed() {
    local cmd="$1"
    shift
    local runtime_home="${TMPDIR:-/tmp}/trinity-office-home"
    local runtime_pythonpath=""
    local runtime_nodepath=""
    local runtime_library_path=""
    local runtime_dri_driver_path=""
    local -a rewritten_args=()
    local rootfs_command=""

    if command_uses_runtime_rootfs "$cmd" && command_requires_rootfs_bwrap "$cmd" && ! command -v bwrap &> /dev/null; then
        echo "WARN: No bwrap found, running in native mode, it could be harmful to your computer!" >&2
    fi

    if command_uses_runtime_rootfs "$cmd" && command_requires_rootfs_bwrap "$cmd" && [ "$USE_BWRAP" != true ]; then
        echo "WARN: No bwrap found, running in native mode, it could be harmful to your computer!" >&2
    fi
    
    if [ "$USE_BWRAP" = true ] && command -v bwrap &> /dev/null; then
        log "Using bubblewrap sandbox"
        local bwrap_args
        bwrap_args=$(build_bwrap_cmd "$cmd")

        if command_uses_runtime_rootfs "$cmd"; then
            rootfs_command="$(discover_rootfs_command_guest_path "$cmd")"
            if [ -n "$WORK_DIR" ]; then
                bwrap $bwrap_args --chdir /work "$rootfs_command" "$@"
            else
                bwrap $bwrap_args "$rootfs_command" "$@"
            fi
            return
        fi
        
        # Change to work directory if specified
        if [ -n "$WORK_DIR" ]; then
            bwrap $bwrap_args --chdir /work /runtime/bin/$cmd "$@"
        else
            bwrap $bwrap_args /runtime/bin/$cmd "$@"
        fi
    else
        if [ "$USE_BWRAP" = true ] && ! command -v bwrap &> /dev/null; then
            echo "WARN: No bwrap found, running in native mode, it could be harmful to your computer!" >&2
        fi
        log "Running without sandbox"
        if [ -n "$WORK_DIR" ]; then
            rewrite_workdir_args "$@"
        else
            rewritten_args=("$@")
        fi

        if command_uses_runtime_rootfs "$cmd"; then
            if [ -n "$WORK_DIR" ]; then
                (
                    cd "$WORK_DIR" && \
                    run_rootfs_command_without_sandbox "$cmd" "${rewritten_args[@]}"
                )
            else
                run_rootfs_command_without_sandbox "$cmd" "${rewritten_args[@]}"
            fi
            return
        fi

        mkdir -p "$runtime_home"
        runtime_pythonpath="$(discover_pythonpath "$RUNTIME_DIR")"
        runtime_nodepath="$(discover_node_path "$RUNTIME_DIR")"
        runtime_library_path="$(discover_library_path "$RUNTIME_DIR")"
        if [ -n "$runtime_library_path" ]; then
            runtime_library_path="${runtime_library_path}:/lib:/lib64"
        else
            runtime_library_path="$RUNTIME_DIR/lib:/lib:/lib64"
        fi
        if command_needs_libreoffice_env "$cmd"; then
            runtime_library_path="$(append_path_entry "$runtime_library_path" "$(discover_libreoffice_program_path "$RUNTIME_DIR")" 0)"
            runtime_dri_driver_path="$(discover_dri_driver_path "$RUNTIME_DIR")"
        fi
        if [ -n "$WORK_DIR" ]; then
            (
                cd "$WORK_DIR" && \
                if command_needs_libreoffice_env "$cmd"; then
                    HOME="$runtime_home" \
                    LANG="C.UTF-8" \
                    LC_ALL="C.UTF-8" \
                    PATH="$RUNTIME_DIR/bin:/usr/bin:/bin" \
                    LD_LIBRARY_PATH="$runtime_library_path" \
                    LIBGL_DRIVERS_PATH="$runtime_dri_driver_path" \
                    SAL_DISABLESKIA="1" \
                    LIBGL_ALWAYS_SOFTWARE="1" \
                    URE_BOOTSTRAP="vnd.sun.star.pathname:${RUNTIME_DIR}/lib/libreoffice/program/fundamentalrc" \
                    PYTHONPATH="$runtime_pythonpath" \
                    NODE_PATH="$runtime_nodepath" \
                    "$RUNTIME_DIR/bin/$cmd" "${rewritten_args[@]}"
                else
                    HOME="$runtime_home" \
                    LANG="C.UTF-8" \
                    LC_ALL="C.UTF-8" \
                    PATH="$RUNTIME_DIR/bin:/usr/bin:/bin" \
                    LD_LIBRARY_PATH="$runtime_library_path" \
                    PYTHONPATH="$runtime_pythonpath" \
                    NODE_PATH="$runtime_nodepath" \
                    "$RUNTIME_DIR/bin/$cmd" "${rewritten_args[@]}"
                fi
            )
        else
            if command_needs_libreoffice_env "$cmd"; then
                HOME="$runtime_home" \
                LANG="C.UTF-8" \
                LC_ALL="C.UTF-8" \
                PATH="$RUNTIME_DIR/bin:/usr/bin:/bin" \
                LD_LIBRARY_PATH="$runtime_library_path" \
                LIBGL_DRIVERS_PATH="$runtime_dri_driver_path" \
                SAL_DISABLESKIA="1" \
                LIBGL_ALWAYS_SOFTWARE="1" \
                URE_BOOTSTRAP="vnd.sun.star.pathname:${RUNTIME_DIR}/lib/libreoffice/program/fundamentalrc" \
                PYTHONPATH="$runtime_pythonpath" \
                NODE_PATH="$runtime_nodepath" \
                "$RUNTIME_DIR/bin/$cmd" "${rewritten_args[@]}"
            else
                HOME="$runtime_home" \
                LANG="C.UTF-8" \
                LC_ALL="C.UTF-8" \
                PATH="$RUNTIME_DIR/bin:/usr/bin:/bin" \
                LD_LIBRARY_PATH="$runtime_library_path" \
                PYTHONPATH="$runtime_pythonpath" \
                NODE_PATH="$runtime_nodepath" \
                "$RUNTIME_DIR/bin/$cmd" "${rewritten_args[@]}"
            fi
        fi
    fi
}

exec_sandboxed() {
    run_sandboxed "$@"
    exit $?
}

# Convert a presentation to PDF
convert_presentation() {
    local input="$1"
    local input_path
    local output
    local output_path
    
    input_path="$(normalize_existing_file_path "$input")"
    if [ $# -ge 2 ]; then
        output="$2"
        output_path="$(normalize_output_path "$output")"
    else
        output_path="${input_path%.pptx}.pdf"
        output="$(basename "$output_path")"
    fi

    log "Converting: $input_path -> $output_path"
    
    INPUT_DIR="$(cd "$(dirname "$input_path")" && pwd)"
    WORK_DIR="$(cd "$(dirname "$output_path")" && pwd)"
    local input_name
    input_name=$(basename "$input_path")

    generate_pdf_preview "$input_name" "$output_path"
}

# Extract text from a presentation
extract_text() {
    local input="$1"
    local input_path
    
    input_path="$(normalize_existing_file_path "$input")"
    log "Extracting text from: $input_path"

    INPUT_DIR="$(cd "$(dirname "$input_path")" && pwd)"
    WORK_DIR="$INPUT_DIR"
    local input_name
    input_name=$(basename "$input_path")
    
    run_markitdown "/input/$input_name"
}

# Generate thumbnail
generate_thumbnail() {
    local input="$1"
    local input_path
    local output_path
    
    input_path="$(normalize_existing_file_path "$input")"
    if [ $# -ge 2 ]; then
        output_path="$(normalize_output_path "$2")"
    else
        output_path="${input_path%.pptx}.jpg"
    fi

    log "Generating thumbnail: $input_path -> $output_path"

    INPUT_DIR="$(cd "$(dirname "$input_path")" && pwd)"
    WORK_DIR="$(cd "$(dirname "$output_path")" && pwd)"
    local input_name
    input_name=$(basename "$input_path")
    local output_name
    output_name=$(basename "$output_path")
    local intermediate_pdf="${WORK_DIR}/${input_name%.pptx}.pdf"
    
    # Convert to PDF first, then to image
    generate_pdf_preview "$input_name" "$intermediate_pdf"
    run_sandboxed pdftoppm -jpeg -singlefile -r 150 -f 1 -l 1 "/work/${input_name%.pptx}.pdf" "/work/${output_name%.jpg}"
    rm -f "$intermediate_pdf"
}

# Create a presentation from JavaScript
create_presentation() {
    local script="$1"
    local script_path
    local output_path
    
    script_path="$(normalize_existing_file_path "$script")"
    if [ $# -ge 2 ]; then
        output_path="$(normalize_output_path "$2")"
    else
        output_path="$(normalize_output_path "output.pptx")"
    fi

    log "Creating presentation from: $script_path -> $output_path"

    INPUT_DIR="$(cd "$(dirname "$script_path")" && pwd)"
    WORK_DIR="$(cd "$(dirname "$output_path")" && pwd)"
    local script_name
    script_name=$(basename "$script_path")
    local output_name
    output_name=$(basename "$output_path")
    
    run_sandboxed node "/input/$script_name" "/work/$output_name"
}

# Main execution
main() {
    # Check environment overrides
    if [ -n "${TRINITY_OFFICE_RUNTIME:-}" ]; then
        RUNTIME_DIR="$TRINITY_OFFICE_RUNTIME"
    fi
    VERSION_FILE="${RUNTIME_DIR}/VERSION"
    
    if [ "${TRINITY_NO_SANDBOX:-}" = "1" ]; then
        USE_BWRAP=false
    fi
    
    # Parse global options
    while [[ $# -gt 0 ]]; do
        case "$1" in
            -h|--help)
                show_help
                exit 0
                ;;
            -v|--version)
                show_version
                exit 0
                ;;
            --no-sandbox)
                USE_BWRAP=false
                shift
                ;;
            --work-dir)
                CLI_BASE_DIR="$2"
                WORK_DIR="$2"
                shift 2
                ;;
            --verbose)
                VERBOSE=true
                shift
                ;;
            -*)
                echo "Unknown option: $1" >&2
                show_help
                exit 1
                ;;
            *)
                break
                ;;
        esac
    done
    
    # Check runtime directory
    if [ ! -d "$RUNTIME_DIR/bin" ]; then
        echo "Error: Runtime directory not found or invalid: $RUNTIME_DIR" >&2
        echo "Set TRINITY_OFFICE_RUNTIME to the correct path." >&2
        exit 1
    fi

    CLI_BASE_DIR="$(cd "$CLI_BASE_DIR" && pwd)"
    if [ -n "$WORK_DIR" ]; then
        WORK_DIR="$CLI_BASE_DIR"
    fi
    
    # Execute command
    if [ $# -eq 0 ]; then
        show_help
        exit 1
    fi
    
    local command="$1"
    shift
    
    case "$command" in
        convert)
            if [ $# -lt 1 ]; then
                echo "Usage: trinity-office convert <input.pptx> [output.pdf]" >&2
                exit 1
            fi
            convert_presentation "$@"
            ;;
        extract)
            if [ $# -lt 1 ]; then
                echo "Usage: trinity-office extract <input.pptx>" >&2
                exit 1
            fi
            extract_text "$@"
            ;;
        thumbnail)
            if [ $# -lt 1 ]; then
                echo "Usage: trinity-office thumbnail <input.pptx> [output.jpg]" >&2
                exit 1
            fi
            generate_thumbnail "$@"
            ;;
        create)
            if [ $# -lt 1 ]; then
                echo "Usage: trinity-office create <script.js> [output.pptx]" >&2
                exit 1
            fi
            create_presentation "$@"
            ;;
        exec)
            if [ $# -lt 1 ]; then
                echo "Usage: trinity-office exec <command> [args...]" >&2
                exit 1
            fi
            exec_sandboxed "$@"
            ;;
        *)
            echo "Unknown command: $command" >&2
            show_help
            exit 1
            ;;
    esac
}

main "$@"
