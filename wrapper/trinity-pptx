#!/bin/bash
#
# Trinity PPTX Runtime - Main Entry Point
# Wraps LibreOffice, Python tools, and Node.js in a sandboxed environment
#

set -euo pipefail

# Configuration
SCRIPT_DIR="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")" && pwd)"
RUNTIME_DIR="${SCRIPT_DIR}"
VERSION_FILE="${RUNTIME_DIR}/VERSION"

# Add runtime bin directory to PATH for internal commands
export PATH="${RUNTIME_DIR}/bin:${PATH}"

# Default settings
USE_BWRAP=true
BWRAP_OPTS=""
WORK_DIR=""
VERBOSE=false

# Show version
show_version() {
    if [ -f "$VERSION_FILE" ]; then
        head -n1 "$VERSION_FILE"
    else
        echo "unknown"
    fi
}

# Show help
show_help() {
    cat << 'EOF'
Trinity PPTX Runtime - Process PPTX files in a sandboxed environment

Usage: trinity-pptx [OPTIONS] COMMAND [ARGS...]

Commands:
  convert <input.pptx> [output.pdf]    Convert PPTX to PDF
  extract <input.pptx>                 Extract text content from PPTX
  thumbnail <input.pptx> [output.jpg]  Generate thumbnail preview
  create <script.js> [output.pptx]     Create PPTX from JavaScript (pptxgenjs)
  exec <command> [args...]             Execute arbitrary command in sandbox

Options:
  -h, --help           Show this help message
  -v, --version        Show version information
  --no-sandbox         Disable bubblewrap sandbox (not recommended)
  --work-dir <dir>     Set working directory for input/output files
  --verbose            Enable verbose output

Examples:
  trinity-pptx convert presentation.pptx output.pdf
  trinity-pptx extract slides.pptx
  trinity-pptx create my-presentation.js deck.pptx
  trinity-pptx exec python3 -m markitdown presentation.pptx

Environment Variables:
  TRINITY_PPTX_RUNTIME    Path to runtime directory (overrides auto-detect)
  TRINITY_NO_SANDBOX      Set to "1" to disable sandbox
  TRINITY_BWRAP_OPTS      Additional bubblewrap options

EOF
}

# Log verbose messages
log() {
    if [ "$VERBOSE" = true ]; then
        echo "[trinity-pptx] $*" >&2
    fi
}

# Detect if running in sandboxed environment
needs_shim() {
    # Check if AF_UNIX sockets are blocked
    python3 -c "import socket; s = socket.socket(socket.AF_UNIX, socket.SOCK_STREAM); s.close()" 2>/dev/null || return 0
    return 1
}

discover_pythonpath() {
    local prefix="${1:-/runtime}"
    local path
    local python_path=""

    while IFS= read -r path; do
        if [ -n "$python_path" ]; then
            python_path="${python_path}:"
        fi
        python_path="${python_path}${prefix}${path#$RUNTIME_DIR}"
    done < <(find "$RUNTIME_DIR/lib" -mindepth 2 -maxdepth 2 -type d \( -name dist-packages -o -name site-packages \) | sort)

    echo "$python_path"
}

discover_node_path() {
    local prefix="${1:-/runtime}"
    local path
    local node_path=""

    while IFS= read -r path; do
        if [ -n "$node_path" ]; then
            node_path="${node_path}:"
        fi
        node_path="${node_path}${prefix}${path#$RUNTIME_DIR}"
    done < <(find "$RUNTIME_DIR/lib" -mindepth 1 -maxdepth 2 -type d -name node_modules | sort)

    echo "$node_path"
}

append_path_entry() {
    local current="$1"
    local entry="$2"
    local require_dir_check="${3:-1}"

    if [ -z "$entry" ]; then
        echo "$current"
        return
    fi

    if [ "$require_dir_check" = "1" ] && [ ! -d "$entry" ]; then
        echo "$current"
        return
    fi

    if [ -z "$current" ]; then
        echo "$entry"
        return
    fi

    case ":$current:" in
        *":$entry:"*)
            echo "$current"
            ;;
        *)
            echo "${current}:$entry"
            ;;
    esac
}

discover_library_path() {
    local prefix="${1:-/runtime}"
    local library_path=""
    local dir
    local root
    local -a library_roots=("$RUNTIME_DIR/lib" "$RUNTIME_DIR/usr/lib")

    # Keep the loader path constrained to runtime system-library roots.
    # Scanning every .so-containing directory (for example Python package
    # trees) is too broad and can destabilize non-sandboxed Python startup.
    for root in "${library_roots[@]}"; do
        if [ ! -d "$root" ]; then
            continue
        fi

        library_path="$(append_path_entry "$library_path" "${prefix}${root#$RUNTIME_DIR}" 0)"

        while IFS= read -r dir; do
            library_path="$(append_path_entry "$library_path" "${prefix}${dir#$RUNTIME_DIR}" 0)"
        done < <(find "$root" -mindepth 1 -maxdepth 1 -type d -name '*-linux-gnu' | sort)
    done

    echo "$library_path"
}

discover_libreoffice_program_path() {
    local prefix="${1:-/runtime}"
    local program_path="${prefix}/lib/libreoffice/program"

    if [ -d "$RUNTIME_DIR/lib/libreoffice/program" ]; then
        echo "$program_path"
    else
        echo ""
    fi
}

discover_dri_driver_path() {
    local prefix="${1:-/runtime}"
    local path
    local dri_path=""
    local root
    local -a library_roots=("$RUNTIME_DIR/lib" "$RUNTIME_DIR/usr/lib")

    for root in "${library_roots[@]}"; do
        if [ ! -d "$root" ]; then
            continue
        fi

        while IFS= read -r path; do
            if [ -n "$dri_path" ]; then
                dri_path="${dri_path}:"
            fi
            dri_path="${dri_path}${prefix}${path#$RUNTIME_DIR}"
        done < <(find "$root" -mindepth 2 -maxdepth 4 -type d -name dri | sort)
    done

    echo "$dri_path"
}

command_needs_libreoffice_env() {
    case "${1:-}" in
        soffice)
            return 0
            ;;
        *)
            return 1
            ;;
    esac
}

rewrite_workdir_args() {
    local arg

    if [ -z "$WORK_DIR" ]; then
        printf '%s\0' "$@"
        return
    fi

    for arg in "$@"; do
        case "$arg" in
            /work)
                printf '%s\0' "$WORK_DIR"
                ;;
            /work/*)
                printf '%s\0' "${WORK_DIR}/${arg#/work/}"
                ;;
            *)
                printf '%s\0' "$arg"
                ;;
        esac
    done
}

# Setup environment variables for LibreOffice
setup_env() {
    local tool_cmd="${1:-}"
    local env_vars=""
    local python_path=""
    local node_path=""
    local library_path=""
    local libreoffice_program_path=""
    local dri_driver_path=""
    
    # Set HOME to a writable tmpfs location
    env_vars="${env_vars} --setenv HOME /tmp/home"
    
    # Add runtime bin to PATH for node, python, etc.
    env_vars="${env_vars} --setenv PATH /runtime/bin:/usr/bin:/bin"

    # Ensure bundled Python packages are importable across both /usr and
    # /usr/local-derived layouts.
    python_path="$(discover_pythonpath /runtime)"
    if [ -n "$python_path" ]; then
        env_vars="${env_vars} --setenv PYTHONPATH ${python_path}"
    fi
    
    if command_needs_libreoffice_env "$tool_cmd"; then
        # Generic runtime commands do not need an overridden loader path and are
        # more stable without one. Keep the loader override only for LibreOffice.
        library_path="$(discover_library_path /runtime)"
        libreoffice_program_path="$(discover_libreoffice_program_path /runtime)"
        library_path="$(append_path_entry "$library_path" "$libreoffice_program_path" 0)"
        if [ -n "$library_path" ]; then
            env_vars="${env_vars} --setenv LD_LIBRARY_PATH ${library_path}:/lib:/lib64"
        else
            env_vars="${env_vars} --setenv LD_LIBRARY_PATH /runtime/lib:/lib:/lib64"
        fi
    fi
    
    # Node.js modules path
    node_path="$(discover_node_path /runtime)"
    if [ -n "$node_path" ]; then
        env_vars="${env_vars} --setenv NODE_PATH ${node_path}"
    fi

    if command_needs_libreoffice_env "$tool_cmd"; then
        # Prefer deterministic software rendering for headless LibreOffice use.
        env_vars="${env_vars} --setenv SAL_DISABLESKIA 1"
        env_vars="${env_vars} --setenv LIBGL_ALWAYS_SOFTWARE 1"

        dri_driver_path="$(discover_dri_driver_path /runtime)"
        if [ -n "$dri_driver_path" ]; then
            env_vars="${env_vars} --setenv LIBGL_DRIVERS_PATH ${dri_driver_path}"
        fi

        # LibreOffice specific paths
        env_vars="${env_vars} --setenv URE_BOOTSTRAP vnd.sun.star.pathname:/runtime/lib/libreoffice/program/fundamentalrc"
    fi
    
    echo "$env_vars"
}

# Build bubblewrap command
build_bwrap_cmd() {
    local tool_cmd="${1:-}"
    local cmd=""
    
    # Basic sandbox setup
    cmd="${cmd} --unshare-all"
    cmd="${cmd} --share-net"
    cmd="${cmd} --die-with-parent"
    
    # Mount runtime as read-only
    cmd="${cmd} --ro-bind ${RUNTIME_DIR} /runtime"
    
    # Mount system directories for dependencies
    cmd="${cmd} --ro-bind /bin /bin"
    cmd="${cmd} --ro-bind /lib /lib"
    cmd="${cmd} --ro-bind /lib64 /lib64"
    cmd="${cmd} --ro-bind /usr/bin /usr/bin"
    cmd="${cmd} --ro-bind /usr/lib /usr/lib"
    cmd="${cmd} --ro-bind /usr/lib64 /usr/lib64"
    cmd="${cmd} --ro-bind /usr/share /usr/share"
    cmd="${cmd} --ro-bind /etc /etc"
    
    # Proc and dev filesystems
    cmd="${cmd} --proc /proc"
    cmd="${cmd} --dev /dev"
    
    # Temporary directories
    cmd="${cmd} --tmpfs /tmp"
    cmd="${cmd} --tmpfs /tmp/home"
    
    # Working directory (if specified)
    if [ -n "$WORK_DIR" ] && [ -d "$WORK_DIR" ]; then
        cmd="${cmd} --bind ${WORK_DIR} /work"
        cmd="${cmd} --setenv WORKDIR /work"
    fi
    
    # Environment variables
    cmd="${cmd} $(setup_env "$tool_cmd")"
    
    # Additional user-specified options
    if [ -n "${TRINITY_BWRAP_OPTS:-}" ]; then
        cmd="${cmd} ${TRINITY_BWRAP_OPTS}"
    fi
    
    echo "$cmd"
}

# Execute command in sandbox
exec_sandboxed() {
    local cmd="$1"
    shift
    local runtime_home="${TMPDIR:-/tmp}/trinity-pptx-home"
    local runtime_pythonpath=""
    local runtime_nodepath=""
    local runtime_library_path=""
    local runtime_dri_driver_path=""
    local -a rewritten_args=()
    
    if [ "$USE_BWRAP" = true ] && command -v bwrap &> /dev/null; then
        log "Using bubblewrap sandbox"
        local bwrap_args
        bwrap_args=$(build_bwrap_cmd "$cmd")
        
        # Change to work directory if specified
        if [ -n "$WORK_DIR" ]; then
            exec bwrap $bwrap_args --chdir /work /runtime/bin/$cmd "$@"
        else
            exec bwrap $bwrap_args /runtime/bin/$cmd "$@"
        fi
    else
        log "Running without sandbox"
        mkdir -p "$runtime_home"
        runtime_pythonpath="$(discover_pythonpath "$RUNTIME_DIR")"
        runtime_nodepath="$(discover_node_path "$RUNTIME_DIR")"
        if command_needs_libreoffice_env "$cmd"; then
            runtime_library_path="$(discover_library_path "$RUNTIME_DIR")"
            runtime_library_path="$(append_path_entry "$runtime_library_path" "$(discover_libreoffice_program_path "$RUNTIME_DIR")" 0)"
            runtime_dri_driver_path="$(discover_dri_driver_path "$RUNTIME_DIR")"
            if [ -n "$runtime_library_path" ]; then
                runtime_library_path="${runtime_library_path}:/lib:/lib64"
            else
                runtime_library_path="$RUNTIME_DIR/lib:/lib:/lib64"
            fi
        fi
        if [ -n "$WORK_DIR" ]; then
            mapfile -d '' -t rewritten_args < <(rewrite_workdir_args "$@")
        else
            rewritten_args=("$@")
        fi
        if [ -n "$WORK_DIR" ]; then
            (
                cd "$WORK_DIR" && \
                if command_needs_libreoffice_env "$cmd"; then
                    HOME="$runtime_home" \
                    PATH="$RUNTIME_DIR/bin:/usr/bin:/bin" \
                    LD_LIBRARY_PATH="$runtime_library_path" \
                    LIBGL_DRIVERS_PATH="$runtime_dri_driver_path" \
                    SAL_DISABLESKIA="1" \
                    LIBGL_ALWAYS_SOFTWARE="1" \
                    URE_BOOTSTRAP="vnd.sun.star.pathname:${RUNTIME_DIR}/lib/libreoffice/program/fundamentalrc" \
                    PYTHONPATH="$runtime_pythonpath" \
                    NODE_PATH="$runtime_nodepath" \
                    exec "$RUNTIME_DIR/bin/$cmd" "${rewritten_args[@]}"
                else
                    HOME="$runtime_home" \
                    PATH="$RUNTIME_DIR/bin:/usr/bin:/bin" \
                    PYTHONPATH="$runtime_pythonpath" \
                    NODE_PATH="$runtime_nodepath" \
                    exec "$RUNTIME_DIR/bin/$cmd" "${rewritten_args[@]}"
                fi
            )
        else
            if command_needs_libreoffice_env "$cmd"; then
                HOME="$runtime_home" \
                PATH="$RUNTIME_DIR/bin:/usr/bin:/bin" \
                LD_LIBRARY_PATH="$runtime_library_path" \
                LIBGL_DRIVERS_PATH="$runtime_dri_driver_path" \
                SAL_DISABLESKIA="1" \
                LIBGL_ALWAYS_SOFTWARE="1" \
                URE_BOOTSTRAP="vnd.sun.star.pathname:${RUNTIME_DIR}/lib/libreoffice/program/fundamentalrc" \
                PYTHONPATH="$runtime_pythonpath" \
                NODE_PATH="$runtime_nodepath" \
                exec "$RUNTIME_DIR/bin/$cmd" "${rewritten_args[@]}"
            else
                HOME="$runtime_home" \
                PATH="$RUNTIME_DIR/bin:/usr/bin:/bin" \
                PYTHONPATH="$runtime_pythonpath" \
                NODE_PATH="$runtime_nodepath" \
                exec "$RUNTIME_DIR/bin/$cmd" "${rewritten_args[@]}"
            fi
        fi
    fi
}

# Convert PPTX to PDF
convert_pptx() {
    local input="$1"
    local output="${2:-${input%.pptx}.pdf}"
    
    log "Converting: $input -> $output"
    
    if [ ! -f "$input" ]; then
        echo "Error: Input file not found: $input" >&2
        exit 1
    fi
    
    # Set work directory to input file's directory
    WORK_DIR="$(cd "$(dirname "$input")" && pwd)"
    local input_name
    input_name=$(basename "$input")
    local output_name
    output_name=$(basename "$output")
    
    exec_sandboxed soffice --headless --convert-to pdf --outdir /work "/work/$input_name"
    
    # Rename if output name differs
    if [ "$input_name" != "${output_name%.pdf}.pptx" ]; then
        mv "$WORK_DIR/${input_name%.pptx}.pdf" "$WORK_DIR/$output_name"
    fi
}

# Extract text from PPTX
extract_text() {
    local input="$1"
    
    log "Extracting text from: $input"
    
    if [ ! -f "$input" ]; then
        echo "Error: Input file not found: $input" >&2
        exit 1
    fi
    
    WORK_DIR="$(cd "$(dirname "$input")" && pwd)"
    local input_name
    input_name=$(basename "$input")
    
    exec_sandboxed python3 -m markitdown "/work/$input_name"
}

# Generate thumbnail
generate_thumbnail() {
    local input="$1"
    local output="${2:-${input%.pptx}.jpg}"
    
    log "Generating thumbnail: $input -> $output"
    
    if [ ! -f "$input" ]; then
        echo "Error: Input file not found: $input" >&2
        exit 1
    fi
    
    WORK_DIR="$(cd "$(dirname "$input")" && pwd)"
    local input_name
    input_name=$(basename "$input")
    local output_name
    output_name=$(basename "$output")
    
    # Convert to PDF first, then to image
    exec_sandboxed soffice --headless --convert-to pdf --outdir /tmp "/work/$input_name"
    exec_sandboxed pdftoppm -jpeg -r 150 -f 1 -l 1 "/tmp/${input_name%.pptx}.pdf" "/work/${output_name%.jpg}"
}

# Create PPTX from JavaScript
create_pptx() {
    local script="$1"
    local output="${2:-output.pptx}"
    
    log "Creating PPTX from: $script -> $output"
    
    if [ ! -f "$script" ]; then
        echo "Error: Script file not found: $script" >&2
        exit 1
    fi
    
    WORK_DIR="$(cd "$(dirname "$script")" && pwd)"
    local script_name
    script_name=$(basename "$script")
    
    exec_sandboxed node "/work/$script_name" "/work/$output"
}

# Main execution
main() {
    # Check environment overrides
    if [ -n "${TRINITY_PPTX_RUNTIME:-}" ]; then
        RUNTIME_DIR="$TRINITY_PPTX_RUNTIME"
    fi
    
    if [ "${TRINITY_NO_SANDBOX:-}" = "1" ]; then
        USE_BWRAP=false
    fi
    
    # Parse global options
    while [[ $# -gt 0 ]]; do
        case "$1" in
            -h|--help)
                show_help
                exit 0
                ;;
            -v|--version)
                show_version
                exit 0
                ;;
            --no-sandbox)
                USE_BWRAP=false
                shift
                ;;
            --work-dir)
                WORK_DIR="$2"
                shift 2
                ;;
            --verbose)
                VERBOSE=true
                shift
                ;;
            -*)
                echo "Unknown option: $1" >&2
                show_help
                exit 1
                ;;
            *)
                break
                ;;
        esac
    done
    
    # Check runtime directory
    if [ ! -d "$RUNTIME_DIR/bin" ]; then
        echo "Error: Runtime directory not found or invalid: $RUNTIME_DIR" >&2
        echo "Set TRINITY_PPTX_RUNTIME to the correct path." >&2
        exit 1
    fi
    
    # Execute command
    if [ $# -eq 0 ]; then
        show_help
        exit 1
    fi
    
    local command="$1"
    shift
    
    case "$command" in
        convert)
            if [ $# -lt 1 ]; then
                echo "Usage: trinity-pptx convert <input.pptx> [output.pdf]" >&2
                exit 1
            fi
            convert_pptx "$@"
            ;;
        extract)
            if [ $# -lt 1 ]; then
                echo "Usage: trinity-pptx extract <input.pptx>" >&2
                exit 1
            fi
            extract_text "$@"
            ;;
        thumbnail)
            if [ $# -lt 1 ]; then
                echo "Usage: trinity-pptx thumbnail <input.pptx> [output.jpg]" >&2
                exit 1
            fi
            generate_thumbnail "$@"
            ;;
        create)
            if [ $# -lt 1 ]; then
                echo "Usage: trinity-pptx create <script.js> [output.pptx]" >&2
                exit 1
            fi
            create_pptx "$@"
            ;;
        exec)
            if [ $# -lt 1 ]; then
                echo "Usage: trinity-pptx exec <command> [args...]" >&2
                exit 1
            fi
            exec_sandboxed "$@"
            ;;
        *)
            echo "Unknown command: $command" >&2
            show_help
            exit 1
            ;;
    esac
}

main "$@"
